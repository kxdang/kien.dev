---
import "@fontsource-variable/newsreader";
import "@fontsource-variable/newsreader/wght-italic.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "../styles/global.css";

const title = "Kien Dang — Software Engineer";
const description =
  "Software engineer in Toronto. Biochemist on paper, self-taught developer, now building frontend and healthcare data platforms. Lab notebook edition.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://kien.dev" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <script is:inline>
      // theme + js flag, before paint
      document.documentElement.classList.add("js");
      const stored =
        new URLSearchParams(location.search).get("theme") ||
        localStorage.getItem("theme");
      const dark =
        stored === "dark" ||
        (!stored && matchMedia("(prefers-color-scheme: dark)").matches);
      if (dark) document.documentElement.dataset.theme = "dark";
    </script>
  </head>
  <body>
    <div class="page">
      <slot />
    </div>
    <script>
      // reveal-on-scroll
      const els = document.querySelectorAll(".reveal");
      if (matchMedia("(prefers-reduced-motion: reduce)").matches) {
        els.forEach((el) => el.classList.add("in"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("in");
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px" }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
